{
  "name": "@toolplane/cli",
  "version": "0.0.0",
  "private": true,
  "description": "ToolGuard CLI process wrapper for safe shell, git, test, and coding-agent supervision.",
  "type": "module",
  "bin": {
    "toolplane": "./dist/bin/toolplane.js",
    "toolguard": "./dist/bin/toolplane.js"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc --build tsconfig.json",
    "lint": "pnpm typecheck",
    "test": "vitest run",
    "typecheck": "tsc --noEmit --project tsconfig.json && tsc --noEmit --project tsconfig.test.json"
  },
  "dependencies": {
    "@toolplane/core": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^24.10.0",
    "typescript": "^5.9.3",
    "vitest": "4.0.15"
  }
}
