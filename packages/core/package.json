{
  "name": "@toolplane/core",
  "version": "0.0.0",
  "private": true,
  "description": "Protocol-independent ToolGuard core contracts, events, and evidence primitives.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc --build tsconfig.json",
    "demo:raw-failure": "pnpm build && node dist/demo.js raw-failure",
    "demo:toolplane": "pnpm build && node dist/demo.js toolplane",
    "doctor:integrations": "pnpm build && node dist/integration-doctor.js",
    "dev": "pnpm build && node dist/server.js",
    "lint": "pnpm typecheck",
    "test": "vitest run",
    "typecheck": "tsc --noEmit --project tsconfig.json && tsc --noEmit --project tsconfig.test.json"
  },
  "devDependencies": {
    "@types/node": "^24.10.0",
    "typescript": "^5.9.3",
    "vitest": "4.0.15"
  }
}
