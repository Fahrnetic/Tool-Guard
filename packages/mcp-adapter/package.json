{
  "name": "@toolplane/mcp-adapter",
  "version": "0.0.0",
  "private": true,
  "description": "ToolGuard MCP proxy/router adapter for upstream MCP clients and downstream MCP tools.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc --build tsconfig.json",
    "demo": "pnpm build && node dist/demo.js",
    "lint": "pnpm typecheck",
    "test": "vitest run",
    "typecheck": "tsc --noEmit --project tsconfig.json && tsc --noEmit --project tsconfig.test.json"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@toolplane/core": "workspace:*",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^24.10.0",
    "typescript": "^5.9.3",
    "vitest": "4.0.15"
  }
}
